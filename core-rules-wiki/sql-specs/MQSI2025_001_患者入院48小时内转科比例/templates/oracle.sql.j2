SELECT
  CASE
    WHEN COUNT({% if custom_rules.count_multiple_transfers %}*{% else %}DISTINCT {{ fields.admission_id }}{% endif %}) = 0 THEN 0
    ELSE ROUND(
      COUNT(
        {% if not custom_rules.count_multiple_transfers %}DISTINCT {% endif %}CASE
          WHEN {{ fields.transfer_time }} IS NOT NULL
           AND (CAST({{ fields.transfer_time }} AS DATE) - CAST({{ fields.admit_time }} AS DATE)) * 24 <= :transfer_hours_threshold
          THEN {% if custom_rules.count_multiple_transfers %}1{% else %}{{ fields.admission_id }}{% endif %}
        END
      ) / COUNT({% if custom_rules.count_multiple_transfers %}*{% else %}DISTINCT {{ fields.admission_id }}{% endif %}) * 100,
      2
    )
  END AS index_value
FROM {{ main_table }}
WHERE {{ fields.hospital_id }} = :hospital_id
  AND {{ fields.admit_time }} >= :start_time
  AND {{ fields.admit_time }} < :end_time
{% for dept in custom_rules.exclude_dept_filters %}
  AND {{ fields.get('to_dept_id', 'to_dept_id') }} != :{{ dept.param }}
{% endfor %}
